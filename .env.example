# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your secrets before running locally.
# docker-compose automatically picks up .env from the project root.
# ─────────────────────────────────────────────────────────────────────────────

POSTGRES_DB=idempotency_db
POSTGRES_USER=crescent
POSTGRES_PASSWORD=crescent_secret

REDIS_PASSWORD=redis_secret

# Idempotency window (hours).  Keys older than this may be reused.
APP_IDEMPOTENCY_KEY_EXPIRATION_HOURS=24

# How long (seconds) to wait for a PENDING payment to complete before timing out
APP_IDEMPOTENCY_PENDING_TIMEOUT_SECONDS=300
